{
  "name": "tissue",
  "version": "0.1.0",
  "private": true,
  "description": "TISSUE — autonomous in-play trading desk with a latency radar and a backtest that can't lie",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm build:runtime && pnpm -r build",
    "build:runtime": "node scripts/build-runtime.mjs",
    "build:runtime:daemon": "node scripts/build-runtime.mjs daemon",
    "build:runtime:analyst": "node scripts/build-runtime.mjs analyst",
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "verify:containers": "bash scripts/verify-containers.sh",
    "test": "pnpm --filter @tissue/daemon test:run && pnpm --filter @tissue/analyst test:run",
    "test:run": "pnpm --filter @tissue/daemon test:run",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings 0",
    "daemon": "pnpm --filter @tissue/daemon start",
    "replay": "pnpm --filter @tissue/daemon replay",
    "evaluate:real": "pnpm --filter @tissue/daemon evaluate:real",
    "ci": "pnpm audit --prod --audit-level moderate && pnpm lint && pnpm -r typecheck && pnpm --filter @tissue/daemon test:run && pnpm --filter @tissue/analyst test:run && pnpm build && pnpm verify:runtime && pnpm --filter @tissue/daemon replay",
    "analyst": "pnpm --filter @tissue/analyst serve"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@next/eslint-plugin-next": "^16.2.10",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "esbuild": "0.21.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10",
      "uuid": "11.1.1"
    }
  }
}
