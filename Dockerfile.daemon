FROM node:24-bookworm-slim@sha256:cb4e8f7c443347358b7875e717c29e27bf9befc8f5a26cf18af3c3dec80e58c5 AS base
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

FROM base AS build
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json .npmrc ./
COPY apps/daemon/package.json apps/daemon/package.json
COPY apps/analyst/package.json apps/analyst/package.json
COPY apps/dashboard/package.json apps/dashboard/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY packages/slip/package.json packages/slip/package.json
COPY patches ./patches
RUN pnpm install --frozen-lockfile
COPY policy.toml ./policy.toml
COPY packages/shared ./packages/shared
COPY packages/slip ./packages/slip
COPY apps/daemon ./apps/daemon
COPY vendor/slip-program-7gNEn.idl.json ./vendor/slip-program-7gNEn.idl.json
COPY scripts/build-runtime.mjs ./scripts/build-runtime.mjs
RUN pnpm build:runtime:daemon && pnpm --filter @tissue/daemon deploy --prod --legacy /prod/daemon

FROM node:24-bookworm-slim@sha256:cb4e8f7c443347358b7875e717c29e27bf9befc8f5a26cf18af3c3dec80e58c5 AS runtime
ENV NODE_ENV=production
ENV TISSUE_CORPUS_DIR=/app/corpus
WORKDIR /app
COPY --from=build /prod/daemon/node_modules ./apps/daemon/node_modules
COPY --from=build /app/apps/daemon/dist/main.mjs ./apps/daemon/main.mjs
COPY --from=build /app/apps/daemon/idls ./apps/daemon/idls
COPY --from=build /app/vendor/slip-program-7gNEn.idl.json ./vendor/slip-program-7gNEn.idl.json
COPY --from=build /app/policy.toml ./policy.toml
RUN mkdir -p /app/corpus && chown node:node /app/corpus
EXPOSE 8788
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:8788/ready').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"
USER node
CMD ["node", "apps/daemon/main.mjs"]
