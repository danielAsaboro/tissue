# TISSUE live runtime. Copy to .env and fill in; missing live configuration fails loudly.

TISSUE_MODE=live
TISSUE_NETWORK=devnet
TISSUE_API_PORT=8788
TISSUE_ALLOWED_ORIGINS=http://localhost:3000

# Either provide both credentials directly or point at the JSON written by liveActivate.ts.
TXLINE_JWT=
TXLINE_API_TOKEN=
TXLINE_CREDENTIALS_PATH=./apps/daemon/.keys/apitoken.json

# Solana keypair used for BOTH devnet (subscribe level 1, validate_odds anchoring,
# optional submitted validate_odds transactions) and mainnet pricing input.
TISSUE_KEYPAIR_PATH=./apps/daemon/.keys/tissue.json

# view = real on-chain simulation; transaction = view first, then submit and confirm a tx.
TISSUE_ANCHOR_MODE=view

# RPC endpoints
SOLANA_RPC_DEVNET=https://api.devnet.solana.com
SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com

# TxLINE origins. The selected feed network, credentials, RPC, and program must agree.
TXLINE_DEVNET_ORIGIN=https://txline-dev.txodds.com
TXLINE_MAINNET_ORIGIN=https://txline.txodds.com

# Dashboard server-side connection to the daemon API.
TISSUE_DAEMON_URL=http://127.0.0.1:8788

# --- Analyst layer (read-only narration over the ledger; never decides) ---
# Primary LLM: Groq (OpenAI-compatible). Set GROQ_MODEL to Groq's CURRENT recommended
# tool-use model (see console.groq.com/docs) — default below is current as of build.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback LLM: DGrid gateway (OpenAI-compatible; routes to Claude/GPT).
DGRID_API_KEY=
DGRID_BASE_URL=
DGRID_MODEL=
# Analyst service + dashboard proxy
ANALYST_PORT=8787
ANALYST_URL=http://127.0.0.1:8787
ANALYST_DB_PATH=
