# TISSUE — one identity, both networks. Copy to .env and fill in.

# Solana keypair used for BOTH devnet (subscribe level 1, validate_odds anchoring,
# simulated-book adapter) and mainnet (subscribe level 12 realtime pricing input).
TISSUE_KEYPAIR_PATH=./apps/daemon/.keys/tissue.json

# RPC endpoints
SOLANA_RPC_DEVNET=https://api.devnet.solana.com
SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com

# TxLINE origins (see PRD §4 network split: pricing may use mainnet realtime;
# execution/anchoring/provenance stay devnet)
TXLINE_DEVNET_ORIGIN=https://txline-dev.txodds.com
TXLINE_MAINNET_ORIGIN=https://txline.txodds.com

# Optional: pin a completed fixture for corpus seeding / replay (see corpus/)
TISSUE_SEED_FIXTURE_ID=
